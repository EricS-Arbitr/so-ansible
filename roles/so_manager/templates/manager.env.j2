#!/bin/bash
# =========================================================================
# SO 2.4 Manager answer file — rendered by so-ansible/roles/so_manager.
# Consumed by so-setup at 2.4/main (2.4.211) — we bash-source this file
# BEFORE running so-setup to pre-load every var that gates a whiptail
# prompt. `TESTING=true` causes each whiptail_* function to return early
# (see so-whiptail: `[ -n "$TESTING" ] && return` at the top of every
# ~80 functions) so the TUI never renders and the install proceeds with
# our values. Any UNRECOGNIZED var name is silently ignored — a typo
# means the corresponding whiptail dialog would reappear if TESTING
# weren't set, or silently use an empty value. Cross-check names against
# roles/so_base/files/setup-automation-source/so-whiptail + so-functions
# on every SO version bump. Discovered 2026-07-22: this mechanism works
# on 2.4/main even though the setup/automation/ dir doesn't ship there.
# =========================================================================
#
# CRITICAL: `set -a` auto-exports every var defined below so so-setup
# (a child bash process) sees them in its environment. Without this,
# non-exported bash vars stay in the sourcing shell and so-setup falls
# back to interactive whiptail (which then fails with "Failed to open
# terminal" under Ansible async). Discovered 2026-07-22 after an 18-min
# install died at "User cancelled setup" because TESTING wasn't reaching
# so-setup's process.
set -a

TESTING=true

# --- Networking (STATIC per group_vars) ---
# so_prod_nic + so_prod_netmask computed at task time from ansible_facts
# (see roles/so_manager/tasks/main.yml). Hardcoding either was fragile:
# platform NIC names (ens192 vs ens224) depend on PCI slot ordering and
# netmask can be derived from CIDR prefix. Compute > hardcode.
address_type={{ so_address_type }}
MIP={{ so_prod_ip }}
MMASK={{ so_prod_netmask }}
MGATEWAY={{ so_prod_gateway }}
MDNS={{ so_prod_dns | join(',') }}
MNIC={{ so_prod_nic }}
# MAINIP pre-set to skip so-functions' networking_needful() auto-derivation
# via `ip route get 1` — the SimSpace platform netplan on this image has
# no default route, so that command returns "Network is unreachable" 30
# times before so-setup aborts with "Could not determine MAINIP or
# MNIC_IP" (verified 2026-07-22). MAINIP = the primary in-game NIC's IP
# per line 702 of so-functions: `MAINIP=$MNIC_IP`.
MAINIP={{ so_prod_ip }}
MNIC_IP={{ so_prod_ip }}

# --- Install shape ---
install_type=MANAGER
HOSTNAME={{ so_hostname }}
NIDS={{ so_nids }}
ZEEKVERSION={{ so_zeek_version }}
RULESETUP={{ so_rule_set }}
MANAGERADV={{ so_manager_adv }}
NODESETUP=NODEBASIC
NSMSETUP=BASIC
NODEUPDATES=MANAGER

# Sensible defaults for detection-tuning knobs (match shipped template).
BASICZEEK=7
BASICSURI=7
HNMANAGER=10.0.0.0/8,192.168.0.0/16,172.16.0.0/12
HNSENSOR=inherit

# --- Admin creds ---
ADMINUSER=onionuser
ADMINPASS1={{ vault_so_remote_password }}
ADMINPASS2={{ vault_so_remote_password }}

# --- WebUI (SOC) ---
WEBUSER={{ so_web_user }}
WEBPASSWD1={{ vault_so_web_password }}
WEBPASSWD2={{ vault_so_web_password }}
REDIRECTINFO={{ so_web_access_type }}

# --- so-allow (who can reach the SOC WebUI) ---
ALLOW_CIDR={{ so_allow_subnets | join(',') }}
ALLOW_ROLE=a

# --- Shared secret for search/sensor to join us ---
SOREMOTEPASS1={{ vault_so_remote_password }}
SOREMOTEPASS2={{ vault_so_remote_password }}

# --- Feature toggles (match shipped template defaults) ---
GRAFANA=1
OSQUERY=1
PLAYBOOK=1
STRELKA=1
THEHIVE=0
WAZUH=1

# --- Patch schedule (auto = SO decides) ---
PATCHSCHEDULENAME=auto

# --- Suppress SO's own post-install reboot ---
# We reboot from Ansible so we can wait_for_connection reliably.
SKIP_REBOOT=1

# Turn auto-export off (belt-and-suspenders — nothing after this needs it)
set +a
