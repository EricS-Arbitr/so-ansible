#!/bin/bash
# =========================================================================
# SO 2.4 Search node answer file — rendered by so-ansible/roles/so_search.
# Bash-sourced before so-setup runs; TESTING=true skips every whiptail
# prompt. See roles/so_manager/templates/manager.env.j2 for the full
# story on why this works at 2.4/main and why `set -a` is required.
# =========================================================================
set -a

TESTING=true

# --- Networking (STATIC) ---
address_type={{ so_address_type }}
MIP={{ so_prod_ip }}
MMASK={{ so_prod_netmask }}
MGATEWAY={{ so_prod_gateway }}
MDNS={{ so_prod_dns | join(',') }}
MNIC={{ so_prod_nic }}
# MAINIP + MNIC_IP pre-set — see manager.env.j2 for rationale.
MAINIP={{ so_prod_ip }}
MNIC_IP={{ so_prod_ip }}

# --- Install shape ---
install_type=SEARCHNODE
HOSTNAME={{ so_hostname }}

# --- Manager join (shared secret + short hostname resolution via /etc/hosts) ---
MSRV={{ so_msrv }}
MSRVIP={{ so_msrv_ip }}
SOREMOTEPASS1={{ vault_so_remote_password }}
SOREMOTEPASS2={{ vault_so_remote_password }}
MANAGERUPDATES=1

# --- Node role knobs (match shipped template defaults) ---
BASICZEEK=7
BASICSURI=7
HNMANAGER=10.0.0.0/8,192.168.0.0/16,172.16.0.0/12
HNSENSOR=inherit
NSMSETUP=BASIC
NODEUPDATES=MANAGER
PATCHSCHEDULENAME=auto

# --- Admin creds ---
ADMINUSER=onionuser
ADMINPASS1={{ vault_so_remote_password }}
ADMINPASS2={{ vault_so_remote_password }}

# --- Suppress SO's own post-install reboot (Ansible does it) ---
SKIP_REBOOT=1

set +a
