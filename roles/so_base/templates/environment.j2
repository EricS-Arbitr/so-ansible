PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/games:/usr/local/games:/snap/bin"

# HTTP proxy for SO 2.4 network install — added by so_base role.
# so-setup calls out to packages.securityonion.net + Docker + Elastic apt
# repos; those calls need to reach the outside via the mgmt-plane proxy
# at {{ so_upstream_proxy }}. NO_PROXY includes the SO subnet + mgmt plane
# so intra-range HTTP (e.g. pulling the source tarball from the ansible
# mirror) doesn't get proxied.
#
# CRITICAL: no_proxy MUST list explicit hostnames + 127.0.0.1 in addition
# to CIDR ranges. Python's urllib/requests (used by salt's http.query and
# state.http.wait_for_successful_query) does NOT parse CIDR notation for
# no_proxy — only literal hostnames and .domain suffixes. curl accepts
# CIDR. Both are kept so both tools bypass the proxy for loopback + peer
# SO nodes. Discovered 2026-07-23 when kratos's wait_for_successful_query
# probe on http://so-manager:4434/ hit the corp Squid at 10.255.240.1:3128
# instead of the local kratos process, returning 503 forever. The 5-min
# retry ceiling made this look like a kratos hang. Kratos itself was
# healthy the whole time.
http_proxy="{{ so_upstream_proxy }}"
https_proxy="{{ so_upstream_proxy }}"
HTTP_PROXY="{{ so_upstream_proxy }}"
HTTPS_PROXY="{{ so_upstream_proxy }}"
no_proxy="localhost,127.0.0.1,127.0.0.0/8,10.255.240.0/20,{{ so_subnet_security }},{{ so_subnet_operations }},{{ so_subnet_engineering }},{{ so_subnet_services }}{% for h in groups['so_all'] %},{{ h }},{{ h }}.localdomain{% endfor %}"
NO_PROXY="localhost,127.0.0.1,127.0.0.0/8,10.255.240.0/20,{{ so_subnet_security }},{{ so_subnet_operations }},{{ so_subnet_engineering }},{{ so_subnet_services }}{% for h in groups['so_all'] %},{{ h }},{{ h }}.localdomain{% endfor %}"
