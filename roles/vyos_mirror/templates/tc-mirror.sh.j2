#!/bin/bash
# ============================================================
# so-mirror tc rules — mirror source interfaces into GRE tun0.
# Managed by so-ansible/roles/vyos_mirror. Do not hand-edit.
# ============================================================
# VyOS declarative CLI doesn't support "mirror ethX -> tunN" so we drop
# to raw tc. Invoked from vyatta-postconfig-bootup.script; safe to run
# repeatedly.
#
# Sources fingerprint: {{ (vyos_mirror_source_interfaces + [vyos_gre_tunnel_iface]) | join(',') }}

LOG=/tmp/so-mirror-tc.log
exec > >(tee -a "$LOG") 2>&1
echo "[so-mirror] === run at $(date -Iseconds) ==="

FAIL=0
run() {
  "$@"
  local rc=$?
  if [ $rc -ne 0 ]; then
    echo "[so-mirror] FAIL rc=$rc: $*"
    FAIL=$((FAIL+1))
  fi
}

TUN="{{ vyos_gre_tunnel_iface }}"

# Diagnostic — dump all interfaces + existing qdiscs so we can see what
# we're working with when things go sideways.
echo "[so-mirror] ip link show:"
ip -brief link show | sed 's/^/  /'
echo "[so-mirror] existing tc qdisc:"
tc qdisc show | sed 's/^/  /'

# Ensure the tunnel interface is UP before adding tc rules against it.
if ! ip link show "$TUN" >/dev/null 2>&1; then
  echo "[so-mirror] ERROR: $TUN not present. Aborting."
  exit 1
fi
ip link set "$TUN" up

{% for iface in vyos_mirror_source_interfaces %}
# --- {{ iface }} ---
if ! ip link show {{ iface }} >/dev/null 2>&1; then
  echo "[so-mirror] SKIP: {{ iface }} not present on this router"
else
  # Ingress mirror
  tc qdisc del dev {{ iface }} ingress 2>/dev/null
  run tc qdisc add dev {{ iface }} handle ffff: ingress
  run tc filter add dev {{ iface }} parent ffff: matchall action mirred egress mirror dev $TUN

  # Egress mirror
  tc qdisc del dev {{ iface }} root 2>/dev/null
  run tc qdisc add dev {{ iface }} handle 1: root prio
  run tc filter add dev {{ iface }} parent 1: matchall action mirred egress mirror dev $TUN
fi

{% endfor %}

if [ $FAIL -gt 0 ]; then
  echo "[so-mirror] FAILED: $FAIL tc commands returned non-zero (see log)"
  exit 1
fi
echo "[so-mirror] tc rules applied for {{ vyos_mirror_source_interfaces | length }} interfaces -> $TUN"
